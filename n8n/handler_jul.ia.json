    {
      "parameters": {
        "jsCode": "// 1. Separa o Lead do Dicionário\nconst items = $input.all();\nconst dicionarioItem = items.find(item => !item.json.lead_id);\nconst dicionario = dicionarioItem ? dicionarioItem.json : {};\nconst leads = items.filter(item => item.json.lead_id);\n\n// 2. Busca os dados originais do Webhook (sempre disponíveis via $node)\nconst webhookBody = $('Webhook lmresortskommo').item.json.body;\nconst webhookQuery = $('Webhook lmresortskommo').item.json.query;\n\n// 3. Resolve hotel_resort: vem do custom_field do Kommo no caminho 2\n// No caminho 1 já vem do code Filtragem hotel_resort\nconst mapeamento = {\n  'central_gravatal': { name_hotel_resort: 'Central Termas de Gravatal', is_central: true },\n  'hotel_internacional': { name_hotel_resort: 'Hotel Internacional Gravatal', is_central: false },\n  'termas_gravatal': { name_hotel_resort: 'Hotel Termas (Gravatal)', is_central: false },\n  'termas_do_lago': { name_hotel_resort: 'Hotel Termas do Lago', is_central: false },\n  'cabanas': { name_hotel_resort: 'Cabanas Termas Hotel', is_central: false },\n  'park_hotel': { name_hotel_resort: 'Termas Park Hotel', is_central: false },\n  'fazzenda': { name_hotel_resort: 'Fazzenda Park Resort', is_central: false },\n  'ita_thermas': { name_hotel_resort: 'Itá Thermas Resort e Spa', is_central: false },\n  'machadinho_thermas': { name_hotel_resort: 'Machadinho Thermas Resort SPA', is_central: false },\n  'central_jurema': { name_hotel_resort: 'Central Jurema Águas Quentes', is_central: true },\n  'lagos_de_jurema': { name_hotel_resort: 'Lagos de Jurema', is_central: false },\n  'jardins_de_jurema': { name_hotel_resort: 'Jardins de Jurema', is_central: false },\n  'central_piratuba': { name_hotel_resort: 'Central Piratuba', is_central: true },\n  'tirolesa': { name_hotel_resort: 'Hotel Tirolesa', is_central: false },\n  'aguas_de_palmas': { name_hotel_resort: 'Águas de Palmas', is_central: false },\n  'dona_francisca': { name_hotel_resort: 'Dona Francisca', is_central: false },\n  'recanto_cataratas_resort': { name_hotel_resort: 'Recanto Cataratas Resort', is_central: false },\n  'central_resorts': { name_hotel_resort: 'Central Resorts', is_central: true },\n  'mabu_thermas': { name_hotel_resort: 'Mabu Thermas Grand Resort', is_central: false },\n  'vivaz_cataratas': { name_hotel_resort: 'Vivaz Cataratas Resort', is_central: false },\n  'central_gramado': { name_hotel_resort: 'Central Gramado', is_central: true }\n};\n\nconst leadsTratados = leads.map(item => {\n    const lead = item.json;\n\n    const pid = lead.pipeline_id.toString();\n    const sid = lead.status_id.toString();\n    const dadosPipeline = dicionario[pid];\n\n    let nomePipelineTexto = \"Não identificado\";\n    let nomeStatusTexto = \"Não identificado\";\n\n    if (dadosPipeline) {\n        if (dadosPipeline.name) nomePipelineTexto = dadosPipeline.name;\n        if (dadosPipeline.statuses && dadosPipeline.statuses[sid]) {\n            nomeStatusTexto = dadosPipeline.statuses[sid];\n        }\n    }\n\n    // Resolve hotel_resort: tenta do custom_field, fallback para query\n    const hotelResortKey = lead.custom_fields?.HOTEL_RESORT || webhookQuery?.hotel_resort || '';\n    const infoHotel = mapeamento[hotelResortKey] || {};\n    // Se tem buffer usa ele, senão usa a mensagem normal\n    const msgBuffer = lead.custom_fields?.MSG_BUFFER || '';\n    const msgSingle = webhookBody['data[message]'] || '';\n    \n    return {\n        json: {\n            // === DADOS DO HOTEL (padronizado com caminho 1) ===\n            hotel_resort: hotelResortKey,\n            name_hotel_resort: infoHotel.name_hotel_resort || lead.custom_fields?.['Hotel ou Resort'] || '',\n            is_central: infoHotel.is_central ?? false,\n\n            // === QUERY (padronizado com caminho 1) ===\n            query: webhookQuery,\n\n            // === DADOS DO WEBHOOK (ausentes no caminho 2) ===\n            message: msgBuffer ? msgBuffer : msgSingle,\n            lead_id: lead.lead_id?.toString(),\n            contact_id: webhookBody['data[contact_id]'],\n            name: webhookBody['data[name]'],\n            return_url: webhookBody.return_url,\n\n            // === DADOS DO LEAD/CRM ===\n            pipeline_id: lead.pipeline_id,\n            status_id: lead.status_id,\n            price: lead.price,\n            responsible_user_id: lead.responsible_user_id,\n            created_at_unix: lead.created_at_unix,\n            updated_at_unix: lead.updated_at_unix,\n            custom_fields: lead.custom_fields,\n            pipeline_jname: nomePipelineTexto,\n            status_jname: nomeStatusTexto,\n\n            // === METADATA ===\n            origem: 'retorno'\n        }\n    };\n});\n\nreturn leadsTratados;"
      },
