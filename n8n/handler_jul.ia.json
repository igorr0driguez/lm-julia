      "parameters": {
        "jsCode": "// Code Node: Identificar Hotel/Resort (Primeiro Contato)\n// Executa apenas quando query.hotel_resort existe\n\nconst mapeamento = {\n  // CENTRAL TERMAS DE GRAVATAL\n  'central_gravatal': {\n    hotel_resort: 'central_gravatal',\n    name_hotel_resort: 'Central Termas de Gravatal',\n    is_central: true\n  },\n  'hotel_internacional': {\n    hotel_resort: 'hotel_internacional',\n    name_hotel_resort: 'Hotel Internacional Gravatal',\n    is_central: false\n  },\n  'termas_gravatal': {\n    hotel_resort: 'termas_gravatal',\n    name_hotel_resort: 'Hotel Termas (Gravatal)',\n    is_central: false\n  },\n  'termas_do_lago': {\n    hotel_resort: 'termas_do_lago',\n    name_hotel_resort: 'Hotel Termas do Lago',\n    is_central: false\n  },\n  'cabanas': {\n    hotel_resort: 'cabanas',\n    name_hotel_resort: 'Cabanas Termas Hotel',\n    is_central: false\n  },\n  'park_hotel': {\n    hotel_resort: 'park_hotel',\n    name_hotel_resort: 'Termas Park Hotel',\n    is_central: false\n  },\n  'fazzenda': {\n    hotel_resort: 'fazzenda',\n    name_hotel_resort: 'Fazzenda Park Resort',\n    is_central: false\n  },\n  'ita_thermas': {\n    hotel_resort: 'ita_thermas',\n    name_hotel_resort: 'Itá Thermas Resort e Spa',\n    is_central: false\n  },\n  'machadinho_thermas': {\n    hotel_resort: 'machadinho_thermas',\n    name_hotel_resort: 'Machadinho Thermas Resort SPA',\n    is_central: false\n  },\n  \n  // CENTRAL JUREMA ÁGUAS QUENTES\n  'central_jurema': {\n    hotel_resort: 'central_jurema',\n    name_hotel_resort: 'Central Jurema Águas Quentes',\n    is_central: true\n  },\n  'lagos_de_jurema': {\n    hotel_resort: 'lagos_de_jurema',\n    name_hotel_resort: 'Lagos de Jurema',\n    is_central: false\n  },\n  'jardins_de_jurema': {\n    hotel_resort: 'jardins_de_jurema',\n    name_hotel_resort: 'Jardins de Jurema',\n    is_central: false\n  },\n  \n  // CENTRAL PIRATUBA\n  'central_piratuba': {\n    hotel_resort: 'central_piratuba',\n    name_hotel_resort: 'Central Piratuba',\n    is_central: true\n  },\n  'tirolesa': {\n    hotel_resort: 'tirolesa',\n    name_hotel_resort: 'Hotel Tirolesa',\n    is_central: false\n  },\n  'aguas_de_palmas': {\n    hotel_resort: 'aguas_de_palmas',\n    name_hotel_resort: 'Águas de Palmas',\n    is_central: false\n  },\n  'dona_francisca': {\n    hotel_resort: 'dona_francisca',\n    name_hotel_resort: 'Dona Francisca',\n    is_central: false\n  },\n  'recanto_cataratas_resort': {\n    hotel_resort: 'recanto_cataratas_resort',\n    name_hotel_resort: 'Recanto Cataratas Resort',\n    is_central: false\n  },\n  \n  // CENTRAL RESORTS\n  'central_resorts': {\n    hotel_resort: 'central_resorts',\n    name_hotel_resort: 'Central Resorts',\n    is_central: true\n  },\n  'mabu_thermas': {\n    hotel_resort: 'mabu_thermas',\n    name_hotel_resort: 'Mabu Thermas Grand Resort',\n    is_central: false\n  },\n  'vivaz_cataratas': {\n    hotel_resort: 'vivaz_cataratas',\n    name_hotel_resort: 'Vivaz Cataratas Resort',\n    is_central: false\n  },\n  \n  // CENTRAL GRAMADO\n  'central_gramado': {\n    hotel_resort: 'central_gramado',\n    name_hotel_resort: 'Central Gramado',\n    is_central: true\n  }\n};\n\n// Pega o query param (suporta ambos os nomes por compatibilidade)\nconst hotelResortParam = $json.query['hotel_resort'] || $json.query['hotel-resort'];\n\n// Se não encontrou, retorna erro\nif (!hotelResortParam) {\n  console.error('Query param hotel_resort não encontrado');\n  return {\n    erro: true,\n    mensagem: 'Query param hotel_resort ausente',\n    query: $json.query,\n    body: $json.body\n  };\n}\n\n// Busca no mapeamento\nconst info = mapeamento[hotelResortParam];\n\nif (!info) {\n  console.error('Hotel/Resort não mapeado:', hotelResortParam);\n  return {\n    erro: true,\n    mensagem: 'Hotel/Resort não encontrado no mapeamento',\n    hotel_resort_recebido: hotelResortParam,\n    query: $json.query,\n    body: $json.body\n  };\n}\n\n// Retorna todos os dados + info do hotel\nreturn {\n  // Informações do hotel/resort identificado\n  hotel_resort: info.hotel_resort,\n  name_hotel_resort: info.name_hotel_resort,\n  is_central: info.is_central,\n  \n  // Query params completos\n  query: $json.query,\n  \n  // Body completo (exceto token por segurança)\n  message: $json.body['data[message]'],\n  lead_id: $json.body['data[lead_id]'],\n  contact_id: $json.body['data[contact_id]'],\n  name: $json.body['data[name]'],\n  pipeline_id: $json.body['data[pipeline_id]'],\n  return_url: $json.body.return_url,\n  \n  // Metadata\n  origem: 'primeiro_contato'\n};"
      },
